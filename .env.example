OPENAI_API_KEY=your_openai_key

# Chinese for English speakers (duolingo_cn_for_en.py)
DUO_EMAIL=your_email
DUO_PASSWORD=your_password
DUO_PROFILE_URL=YOUR_USERNAME

# English for Vietnamese speakers (duolingo_en_for_vi.py)
VI_DUO_EMAIL=your_email
VI_DUO_PASSWORD=your_password
VI_DUO_PROFILE_URL=YOUR_USERNAME

# Optional: Pre-authenticated JWT token (recommended for CI)
# DUO_JWT=your_jwt_token

# Optional: Limit lessons per run (0 = unlimited)
# MAX_LESSONS=0

# Optional: Run browser headless (true/false)
# HEADLESS=false
